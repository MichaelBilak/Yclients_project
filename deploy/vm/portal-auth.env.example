# Append to /opt/yclients_bi_system/.env (requires root). Generate secret: openssl rand -hex 32

AUTH_JWT_SECRET=replace_with_openssl_rand_hex_32
AUTH_REQUIRE_LOGIN=true
AUTH_EMAIL_VERIFY_REQUIRED=false
APP_PUBLIC_URL=https://yclients-project.vercel.app
AUTH_CONSOLE_EMAIL=true

# Optional bootstrap (used by scripts/deploy_portal_vm.sh):
# PORTAL_ADMIN_EMAIL=you@company.com
# PORTAL_ADMIN_PASSWORD=strong_password_here
# PORTAL_ADMIN_NAME=Super Admin
# PORTAL_PROVISION_STAFF=false
