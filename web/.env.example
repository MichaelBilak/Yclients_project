# Public FastAPI URL for the deployed dashboard.
# Use a stable hostname, for example a named Cloudflare Tunnel or VPS domain.
# Do not use temporary *.trycloudflare.com quick tunnel URLs in production.
VITE_API_BASE=https://api.example.com

# Optional. This value is bundled into browser JavaScript and is visible to users.
# If you enable API_KEY on the backend, set the same value in Vercel only for a
# demo/private dashboard, or protect the app with Cloudflare Access / real auth.
VITE_API_KEY=
