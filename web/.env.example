# Browser-visible API base.
# Production without a domain: use the Vercel Function proxy in web/api/[...path].js.
VITE_API_BASE=/api

# Server-side Vercel Function settings. Add these as Vercel environment variables;
# they are not bundled into browser JavaScript.
VM_API_ORIGIN=http://185.207.65.14
VM_API_KEY=

# Future domain setup:
# VITE_API_BASE=https://api.example.com
