# Browser-visible API base.
VITE_API_BASE=/api

# Server-side proxy settings. Set real values only in deployment secrets.
VM_API_ORIGIN=https://api.example.com
# Legacy: injects X-API-Key when the browser sends no Bearer token. Disable for portal login.
VM_API_KEY=
VM_INJECT_API_KEY=false

# Direct browser API mode for local/private deployments:
# VITE_API_BASE=https://api.example.com
