# YClients API
PARTNER_TOKEN=your_partner_token
YCLIENTS_LOGIN=your_phone_number
YCLIENTS_PASSWORD=your_password
YCLIENTS_REQUEST_DELAY=0.25
YCLIENTS_TIMEOUT=30
YCLIENTS_RETRY_TOTAL=3
YCLIENTS_RETRY_BACKOFF=1.0

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=yclients_db
DB_USER=postgres
DB_PASSWORD=changeme
DB_BATCH_SIZE=1000

# Sync windows
SYNC_DAYS=365
SCHEDULE_DAYS=60
ANALYTICS_DAYS=30
SYNC_INCREMENTAL=true
SYNC_LOOKBACK_DAYS=2
SYNC_LOG_DIR=logs
SYNC_FULL_REFRESH_HOUR=2
SYNC_LOCK_ID=826451
SYNC_API_TOKEN=change_me_sync_api_token
SYNC_WORKER_POLL_INTERVAL=5
SERVICES_LABEL_SYNC_INTERVAL_DAYS=7
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=change_me_strong_api_key

# Optional: comma-separated origins for product dashboard SPA (Vercel), e.g. https://my-app.vercel.app
DASHBOARD_CORS_ORIGINS=
DASHBOARD_CORS_ORIGIN_REGEX=
PLAN_SHEET_CSV_URL=
PLAN_SHEET_ID=
PLAN_SHEET_NAME=plan
SERVICES_SHEET_CSV_URL=
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SERVICE_ACCOUNT_JSON_B64=
SERVICES_SHEET_ID=
SERVICES_SHEET_NAME=services

# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Metabase application DB (used by docker-compose.yml)
MB_DB_NAME=metabase_app

# Portal auth (personal cabinets)
# When API_KEY is set (legacy/proxy deploy), login is optional unless forced here.
AUTH_JWT_SECRET=change_me_local_jwt_secret
AUTH_JWT_EXPIRE_MINUTES=10080
AUTH_REQUIRE_LOGIN=false
AUTH_EMAIL_VERIFY_REQUIRED=true
# Public URL of the SPA (links in emails). Production: https://your-domain.com
APP_PUBLIC_URL=http://127.0.0.1:5173

# Email: confirmation & password reset
# If SMTP_HOST + SMTP_USER + SMTP_PASSWORD are set, letters are sent via SMTP.
# AUTH_CONSOLE_EMAIL=true forces printing links to the API console (dev only).
# AUTH_CONSOLE_EMAIL=false
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your_login@yandex.ru
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_login@yandex.ru
SMTP_USE_TLS=true
SMTP_USE_SSL=true
# Gmail: smtp.gmail.com, port 587, SMTP_USE_SSL=false, SMTP_USE_TLS=true, app password
# Mail.ru: smtp.mail.ru, port 465, SMTP_USE_SSL=true
AUTH_CONSOLE_EMAIL=false
